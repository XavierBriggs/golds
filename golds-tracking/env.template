# Required: Slack webhook URL for notifications
# Get this from your Slack workspace: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: Slack notification settings (defaults shown)
# Interval in seconds between Slack notifications
SLACK_NOTIFY_INTERVAL_SECONDS=20

# Maximum number of log lines to include in each notification
SLACK_NOTIFY_MAX_LINES=25

# Maximum number of characters to include in each notification
SLACK_NOTIFY_MAX_CHARS=3500

# Optional: Directory settings (defaults shown)
# Directory where log files are stored
LOG_DIR=logs

# Directory where run metadata is stored
RUN_META_DIR=runs_meta

